.PHONY : src/state_machine_test.o

# target to build an object file
src/state_machine_test.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/state_machine.dir/build.make CMakeFiles/state_machine.dir/src/state_machine_test.cpp.o
.PHONY : src/state_machine_test.cpp.o

src/state_machine_test.i: src/state_machine_test.cpp.i
.PHONY : src/state_machine_test.i

# target to preprocess a source file
src/state_machine_test.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/state_machine.dir/build.make CMakeFiles/state_machine.dir/src/state_machine_test.cpp.i
.PHONY : src/state_machine_test.cpp.i

src/state_machine_test.s: src/state_machine_test.cpp.s
.PHONY : src/state_machine_test.s

# target to generate assembly for a file
src/state_machine_test.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/state_machine.dir/build.make CMakeFiles/state_machine.dir/src/state_machine_test.cpp.s
.PHONY : src/state_machine_test.cpp.s

